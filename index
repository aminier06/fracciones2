<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Simulador de Regletas y Círculos de Fracciones - Móvil</title>
  <style>
    :root{
      --bg:#f6f8fb;
      --card:#ffffff;
      --line:#d6dce5;
      --text:#1f2937;
      --muted:#6b7280;
      --accent:#2563eb;
      --shadow:0 8px 24px rgba(15,23,42,.08);
      --whole-width:840px;
      --rod-height:44px;
      --grid-step:35px;
      --snap-distance:22px;
    }
    *{box-sizing:border-box}
    body{margin:0;font-family:Arial, Helvetica, sans-serif;background:var(--bg);color:var(--text)}
    header{padding:18px 22px;background:#eef4ff;border-bottom:1px solid #d9e5ff}
    h1{margin:0 0 6px;font-size:1.6rem}
    header p{margin:0;color:#334155;line-height:1.45}
    .layout{display:grid;grid-template-columns:minmax(0,1fr) 440px;gap:16px;padding:16px;align-items:start}
    .panel,.board-wrap{background:var(--card);border:1px solid var(--line);border-radius:16px;box-shadow:var(--shadow)}
    .panel{padding:16px;position:sticky;top:12px;max-height:calc(100vh - 24px);overflow:auto}
    .board-wrap{padding:14px;overflow:hidden}
    .toolbar{display:flex;flex-wrap:wrap;justify-content:space-between;gap:10px;align-items:center;margin-bottom:12px}
    .status{padding:10px 12px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:12px;color:#334155;font-size:.95rem}
    .small{font-size:.92rem;color:var(--muted);line-height:1.45}
    .section-title{margin:0 0 10px;font-size:1rem}
    .row{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px;align-items:center;}
    button,select,input[type="checkbox"]+label{font:inherit}
    button{border:1px solid #c7d2fe;background:rgba(255,255,255,0.4);color:#1e3a8a;padding:8px 12px;border-radius:10px;cursor:pointer;transition:.18s ease}
    button:hover{background:#eff6ff}
    .mode-btn.active{background:var(--accent);color:#fff;border-color:var(--accent)}
    select{padding:8px 10px;border:1px solid var(--line);border-radius:10px;background:#fff}
    .board{
      position:relative;
      min-height:760px;
      border:1px dashed #cbd5e1;
      border-radius:16px;
      background:
        linear-gradient(to right, rgba(148,163,184,.12) 1px, transparent 1px) 0 0 / var(--grid-step) 100%,
        linear-gradient(to bottom, rgba(148,163,184,.07) 1px, transparent 1px) 0 0 / 100% 56px,
        #ffffff;
      overflow:hidden;
    }
    .piece{
      position:absolute;
      cursor:grab;
      user-select:none;
      touch-action:none;
    }
    .piece:active{cursor:grabbing}
    .piece.selected{outline:3px solid #11182733}
    .rod{
      height:var(--rod-height);
      border-radius:0;
      border:1px solid rgba(0,0,0,.45);
      box-shadow:0 4px 10px rgba(15,23,42,.12);
      overflow:hidden;
    }
    .rod .segments{width:100%;height:100%;display:grid}
    .rod .segments span{border-right:1px solid rgba(0,0,0,.35)}
    .rod .segments span:last-child{border-right:none}
    .piece-label{
      position:absolute;inset:0;display:flex;align-items:center;justify-content:center;
      font-weight:700;color:#0f172a;text-shadow:0 1px 0 rgba(255,255,255,.45);
      pointer-events:none;font-size:14px
    }
    .group-label{
      flex-direction:column;
      line-height:1;

      position:absolute;
      height:var(--rod-height);
      display:flex;
      align-items:center;
      justify-content:center;
      font-weight:700;
      color:#0f172a;
      text-shadow:0 1px 0 rgba(255,255,255,.55);
      pointer-events:none;
      z-index:20;
      font-size:16px;
    }
    .palette-guide{border:1px solid #dbe4f0;border-radius:14px;padding:12px;background:#fbfdff}
    .library{display:grid;gap:0;border:2px solid #1f2937;overflow:hidden;border-radius:0;background:rgba(255,255,255,0.4);width:100%}
    .lib-row{display:grid;height:52px;position:relative;border-bottom:2px solid #1f2937}
    .lib-row:last-child{border-bottom:none}
    .lib-cell{
      position:relative;border-right:2px solid rgba(31,41,55,.8);
      display:flex;align-items:center;justify-content:center;
      font-weight:700;color:#0f172a;text-shadow:0 1px 0 rgba(255,255,255,.4);
      cursor:pointer;user-select:none;border-radius:0;
    }
    .lib-cell:last-child{border-right:none}
    .lib-cell:hover{filter:brightness(1.04)}
    .lib-cell::after{content:"";position:absolute;inset:0;background:rgba(255,255,255,.05);pointer-events:none}
    .lib-row.unit .lib-cell{font-size:16px}
    .frac{display:flex;flex-direction:column;align-items:center;line-height:1}
    .frac .top{font-size:16px}
    .frac .bar{width:18px;height:2px;background:#111;margin:4px 0}
    .frac .bottom{font-size:16px}
    .circle-library{display:grid;gap:10px}
    .circle-row{
      display:grid;
      grid-template-columns:72px repeat(auto-fit,minmax(62px,1fr));
      gap:8px;
      align-items:center;
      padding:8px;
      border:1px solid #d8e1ef;
      background:rgba(255,255,255,0.4);
      border-radius:12px;
    }
    .circle-den{font-weight:700;color:#334155;text-align:center}
    .circle-cell{
      height:72px;border:1px solid #d7deea;border-radius:10px;
      display:flex;align-items:center;justify-content:center;cursor:pointer;background:#fbfdff;
    }
    .circle-cell:hover{background:#f3f7ff}
    .circle-icon{
      width:52px;height:52px;border-radius:50%;border:2px solid rgba(15,23,42,.75);
      position:relative;box-shadow:0 2px 6px rgba(15,23,42,.08);
      background:rgba(255,255,255,0.4);
    }
    .circle-piece{
      width:120px;height:120px;border-radius:50%;border:2px solid rgba(15,23,42,.75);
      box-shadow:0 4px 10px rgba(15,23,42,.12);
      background:rgba(255,255,255,0.4);
      overflow:hidden;
    }
    .circle-piece .piece-label{font-size:18px;font-weight:700}
    .hidden{display:none !important}
    .kbd{display:inline-block;border:1px solid #cbd5e1;background:rgba(255,255,255,0.4);border-radius:6px;padding:1px 6px;font-size:.85rem;color:#334155}
    .help-list{margin:8px 0 0 18px;padding:0;color:#475569}
    .help-list li{margin:4px 0}
    footer{padding:8px 18px 18px;color:#64748b;font-size:.9rem;text-align:center}
    @media (max-width:1100px){
      .layout{grid-template-columns:1fr}
      .panel{position:static;max-height:none}
      .board{min-height:720px}
    }
    @media (max-width:768px){
      :root{ --rod-height:40px; }
      body{font-size:16px}
      header{padding:14px 14px 12px}
      h1{font-size:1.2rem;line-height:1.2}
      header p{font-size:.95rem}
      .layout{grid-template-columns:1fr;gap:12px;padding:10px}
      .board-wrap,.panel{border-radius:14px}
      .board-wrap{padding:10px}
      .panel{padding:12px;order:-1}
      .toolbar{flex-direction:column;align-items:stretch;margin-bottom:10px}
      .status,.small{font-size:.92rem}
      .board{min-height:58vh;border-radius:14px}
      .row{gap:10px;margin-bottom:10px}
      button, select{min-height:44px;padding:10px 12px;font-size:16px}
      button{flex:1 1 auto}
      select{width:100%}
      .row label.small{width:100%}
      .palette-guide{padding:10px}
      .lib-row{height:46px}
      .lib-row.unit .lib-cell{font-size:14px}
      .frac .top,.frac .bottom{font-size:13px}
      .frac .bar{width:16px;margin:3px 0}
      .circle-row{grid-template-columns:58px repeat(auto-fit,minmax(54px,1fr));gap:6px;padding:6px}
      .circle-den{font-size:.9rem}
      .circle-cell{height:60px;border-radius:8px}
      .circle-icon{width:42px;height:42px}
      .circle-piece{width:100px;height:100px}
      .circle-piece .piece-label{font-size:16px}
      .piece-label{font-size:13px}
      .group-label{font-size:14px}
      .help-list{margin-left:16px}
      footer{padding:8px 10px 14px;font-size:.82rem}
    }
  </style>
</head>
<body>
  <header>
    <h1>Simulador de regletas y círculos de fracciones móvil</h1>
    <p>A la derecha tienes un panel fijo con dos representaciones: regletas y círculos de fracciones. Haz clic sobre cualquier pieza para crear una copia en el área de comparación y luego arrástrala al lugar que desees.</p>
  </header>

  <main class="layout">
    <section class="board-wrap">
      <div class="toolbar">
        <div class="status" id="statusText">Haz clic en una pieza del panel derecho para llevar una copia al área de comparación.</div>
        <div class="small"><strong>Área de comparación:</strong> usa este espacio para comparar representaciones fraccionarias con regletas o con círculos.</div>
      </div>
      <div class="board" id="board"></div>
    </section>

    <aside class="panel">
      <h2 class="section-title">Materiales disponibles</h2>

      <div class="row">
        <label for="maxDen" class="small">Mostrar hasta denominador:</label>
        <select id="maxDen">
          <option value="6">6</option>
          <option value="8">8</option>
          <option value="10" selected>10</option>
          <option value="12">12</option>
        </select>
      </div>

      <div class="row">
        <button class="mode-btn active" id="showRods">Regletas</button>
        <button class="mode-btn" id="showCircles">Círculos</button>
        <button id="clearBoard">Limpiar tablero</button>
      </div>

      <div class="row">
        <input type="checkbox" id="toggleLabels" checked>
        <label for="toggleLabels">Mostrar etiquetas</label>
      </div>

      <div class="palette-guide">
        <div class="small" style="margin-bottom:10px;"><strong>Instrucción:</strong> selecciona una pieza para llevar una copia al área de trabajo.</div>
        <div id="rodPanel">
          <div class="library" id="rodLibrary"></div>
        </div>
        <div id="circlePanel" class="hidden">
          <div class="circle-library" id="circleLibrary"></div>
        </div>
      </div>

      <div class="small" style="margin-top:14px;"><strong>Cómo usarlo en móvil</strong></div>
      <ul class="help-list small">
        <li>Haz clic en cualquier pieza del panel derecho.</li>
        <li>La copia aparece en el tablero y puedes arrastrarla con el dedo.</li>
        <li>Las regletas se alinean automáticamente al acercarlas.</li>
        <li>Pulsa <span class="kbd">Supr</span> o haz doble clic para eliminar una pieza del tablero.</li>
      </ul>
    </aside>
  </main>

  <footer id="copyright"></footer>

  <script>
    const board = document.getElementById('board');
    const rodLibrary = document.getElementById('rodLibrary');
    const circleLibrary = document.getElementById('circleLibrary');
    const maxDenSelect = document.getElementById('maxDen');
    const statusText = document.getElementById('statusText');
    const toggleLabels = document.getElementById('toggleLabels');
    const copyright = document.getElementById('copyright');
    const rodPanel = document.getElementById('rodPanel');
    const circlePanel = document.getElementById('circlePanel');
    const showRodsBtn = document.getElementById('showRods');
    const showCirclesBtn = document.getElementById('showCircles');

    const WHOLE = 840;
    const SNAP_DISTANCE = 22;
    let pieceCounter = 0;
    let selectedPiece = null;
    let currentMode = 'rods';

    const colors = {
      1:['#1e88ff','#0e6be0'],
      2:['#ff1a1a','#d91010'],
      3:['#ff00cc','#d300a9'],
      4:['#f6e08a','#e6cd6d'],
      5:['#d9ab77','#bf9060'],
      6:['#fff700','#e5de00'],
      7:['#22dbe0','#1abdc1'],
      8:['#ff00ff','#d900d9'],
      9:['#ff9800','#e07f00'],
      10:['#21ff00','#18db00'],
      11:['#a78bfa','#8b5cf6'],
      12:['#f9a8d4','#ec4899']
    };

    function formatFraction(n,d){ return d === 1 ? String(n) : `${n}/${d}`; }

    function gcd(a,b){ return b ? gcd(b, a % b) : a; }

    function simplifyFraction(n,d){
      const g = gcd(n,d);
      return { n: n/g, d: d/g };
    }

    function updateRodGroupLabels(){
      board.querySelectorAll('.group-label').forEach(el => el.remove());

      const rods = Array.from(board.querySelectorAll('.piece[data-kind="rod"]'));
      const visited = new Set();

      rods.forEach(seed => {
        if(visited.has(seed)) return;

        const d = Number(seed.dataset.d);
        const y0 = parseFloat(seed.style.top);
        const group = [seed];
        visited.add(seed);

        let changed = true;
        while(changed){
          changed = false;
          for(const rod of rods){
            if(visited.has(rod)) continue;
            if(Number(rod.dataset.d) !== d) continue;
            const ry = parseFloat(rod.style.top);
            if(Math.abs(ry - y0) > 10) continue;

            const touchesGroup = group.some(g => {
              const gl = parseFloat(g.style.left);
              const gr = gl + g.offsetWidth;
              const rl = parseFloat(rod.style.left);
              const rr = rl + rod.offsetWidth;
              return Math.abs(gr - rl) <= 2 || Math.abs(rr - gl) <= 2 || (rl >= gl && rl <= gr) || (gl >= rl && gl <= rr);
            });

            if(touchesGroup){
              group.push(rod);
              visited.add(rod);
              changed = true;
            }
          }
        }

        group.sort((a,b)=> parseFloat(a.style.left) - parseFloat(b.style.left));
        const totalNumerator = group.reduce((sum, r) => sum + Number(r.dataset.n), 0);

        group.forEach(r => {
          const label = r.querySelector('.piece-label');
          if(label){
            label.style.display = 'none';
          }
        });

        if(toggleLabels.checked){
          const first = group[0];
          const last = group[group.length - 1];
          const left = parseFloat(first.style.left);
          const right = parseFloat(last.style.left) + last.offsetWidth;
          const width = right - left;

          const overlay = document.createElement('div');
          overlay.className = 'group-label';
          overlay.innerHTML = `<span>${totalNumerator}</span><span style="width:20px;height:2px;background:#111;margin:2px 0;"></span><span>${d}</span>`;
          overlay.style.left = left + 'px';
          overlay.style.top = parseFloat(first.style.top) + 'px';
          overlay.style.width = width + 'px';
          board.appendChild(overlay);
        }
      });
    }
    function gradientFor(index){
      const pair = colors[index] || ['#93c5fd','#3b82f6'];
      return `linear-gradient(180deg, ${pair[0]}, ${pair[1]})`;
    }
    function flatColorFor(index){
      const pair = colors[index] || ['#93c5fd','#3b82f6'];
      return pair[0];
    }
    function fractionHTML(d){
      return `<div class="frac"><span class="top">1</span><span class="bar"></span><span class="bottom">${d}</span></div>`;
    }
    function sectorBackground(d, filled=1){
      const deg = 360 / d;
      const color = flatColorFor(d);
      const fillEnd = Math.max(0, Math.min(filled, d)) * deg;
      return `conic-gradient(from -90deg, ${color}80 0deg ${fillEnd}deg, transparent ${fillEnd}deg 360deg)`;
    }

    function buildRodLibrary(maxDen){
      rodLibrary.innerHTML = '';

      const unitRow = document.createElement('div');
      unitRow.className = 'lib-row unit';
      unitRow.style.gridTemplateColumns = '1fr';

      const unitCell = document.createElement('div');
      unitCell.className = 'lib-cell';
      unitCell.style.background = gradientFor(1);
      unitCell.textContent = '1 UNIDAD';
      unitCell.addEventListener('click', ()=> { const pos = findPlacementForRod(1,1); createRod(1,1,pos.x,pos.y); });

      unitRow.appendChild(unitCell);
      rodLibrary.appendChild(unitRow);

      for(let d=2; d<=maxDen; d++){
        const row = document.createElement('div');
        row.className = 'lib-row';
        row.style.gridTemplateColumns = `repeat(${d}, 1fr)`;

        for(let i=0; i<d; i++){
          const cell = document.createElement('div');
          cell.className = 'lib-cell';
          cell.style.background = gradientFor(d);
          cell.innerHTML = fractionHTML(d);
          cell.addEventListener('click', ()=> { const pos = findPlacementForRod(1,d); createRod(1,d,pos.x,pos.y); });
          row.appendChild(cell);
        }
        rodLibrary.appendChild(row);
      }
    }

    function buildCircleLibrary(maxDen){
      circleLibrary.innerHTML = '';

      const unitRow = document.createElement('div');
      unitRow.className = 'circle-row';
      unitRow.innerHTML = `<div class="circle-den">1</div>`;
      const unitCell = document.createElement('div');
      unitCell.className = 'circle-cell';
      unitCell.innerHTML = `<div class="circle-icon" style="background:${flatColorFor(1)};"></div>`;
      unitCell.addEventListener('click', ()=>{
        const pos = findPlacementForCircle(1);
        if(pos.existing){
          selectPiece(pos.existing);
          updateStatus('Ya existe el círculo de unidad en el tablero.');
        } else {
          createCircle(1,1,pos.x,pos.y);
        }
      });
      unitRow.appendChild(unitCell);
      circleLibrary.appendChild(unitRow);

      for(let d=2; d<=maxDen; d++){
        const row = document.createElement('div');
        row.className = 'circle-row';

        const den = document.createElement('div');
        den.className = 'circle-den';
        den.textContent = `1/${d}`;
        row.appendChild(den);

        for(let i=0;i<d;i++){
          const cell = document.createElement('div');
          cell.className = 'circle-cell';
          cell.innerHTML = `<div class="circle-icon" style="background:${sectorBackground(d,1)};"></div>`;
          cell.addEventListener('click', ()=>{
            const pos = findPlacementForCircle(d);
            if(pos.existing){
              const currentFilled = Number(pos.existing.dataset.filled || 1);
              const newFilled = Math.min(d, currentFilled + 1);
              pos.existing.dataset.filled = String(newFilled);
              renderCircle(pos.existing);
              selectPiece(pos.existing);
              updateStatus(`El círculo se acumuló a ${newFilled}/${d}.`);
            } else {
              createCircle(1,d,pos.x,pos.y);
            }
          });
          row.appendChild(cell);
        }
        circleLibrary.appendChild(row);
      }
    }

    function createSegments(container, parts, colorIndex){
      container.style.gridTemplateColumns = `repeat(${parts}, 1fr)`;
      for(let i=0;i<parts;i++){
        const seg = document.createElement('span');
        seg.style.background = gradientFor(colorIndex);
        container.appendChild(seg);
      }
    }


    function findPlacementForRod(n, d){
      const allRods = Array.from(board.querySelectorAll('.piece[data-kind="rod"]'));
      const sameRods = allRods
        .filter(r => Number(r.dataset.n) === n && Number(r.dataset.d) === d)
        .sort((a,b) => {
          const topDiff = parseFloat(a.style.top) - parseFloat(b.style.top);
          if (Math.abs(topDiff) > 6) return topDiff;
          return parseFloat(a.style.left) - parseFloat(b.style.left);
        });

      if(sameRods.length){
        const last = sameRods[sameRods.length - 1];
        const x = parseFloat(last.style.left) + last.offsetWidth;
        const y = parseFloat(last.style.top);
        return {x, y};
      }

      if(!allRods.length){
        return {x:24, y:56};
      }

      const maxTop = Math.max(...allRods.map(r => parseFloat(r.style.top)));
      return {x:24, y:maxTop + 56};
    }

    function createRod(n, d, x=24, y=56){
      pieceCounter += 1;
      const rod = document.createElement('div');
      rod.className = 'piece rod';
      rod.dataset.kind = 'rod';
      rod.dataset.id = pieceCounter;
      rod.dataset.n = n;
      rod.dataset.d = d;
      rod.style.width = (WHOLE * n / d) + 'px';
      const maxX = Math.max(0, board.clientWidth - (WHOLE * n / d));
      if(x > maxX){
        x = 24;
        y = y + 56;
      }
      rod.style.left = x + 'px';
      rod.style.top = y + 'px';

      const segments = document.createElement('div');
      segments.className = 'segments';
      createSegments(segments, n, d);
      rod.appendChild(segments);

      const label = document.createElement('div');
      label.className = 'piece-label';
      label.textContent = formatFraction(n,d);
      label.style.display = toggleLabels.checked ? 'flex' : 'none';
      rod.appendChild(label);

      attachPieceEvents(rod);
      board.appendChild(rod);
      selectPiece(rod);
      updateRodGroupLabels();
      updateStatus(`Se agregó la regleta ${formatFraction(n,d)} al tablero.`);
    }

    function renderCircle(circle){
      const d = Number(circle.dataset.d);
      const filled = Number(circle.dataset.filled || 1);
      circle.style.background = d === 1 ? flatColorFor(1) : sectorBackground(d, filled);
      const label = circle.querySelector('.piece-label');
      if(label){
        label.textContent = d === 1 ? '1' : `${filled}/${d}`;
        label.style.display = toggleLabels.checked ? 'flex' : 'none';
      }
    }


    function findPlacementForCircle(d){
      const allCircles = Array.from(board.querySelectorAll('.piece[data-kind="circle"]'))
        .sort((a,b)=> parseFloat(a.style.top) - parseFloat(b.style.top));

      const sameCircle = allCircles.find(c => Number(c.dataset.d) === d);
      if(sameCircle){
        return { x: parseFloat(sameCircle.style.left), y: parseFloat(sameCircle.style.top), existing: sameCircle };
      }

      if(!allCircles.length){
        return { x: 40, y: 24, existing: null };
      }

      const last = allCircles[allCircles.length - 1];
      const nextY = parseFloat(last.style.top) + last.offsetHeight + 16;
      return { x: 40, y: nextY, existing: null };
    }

    function createCircle(n, d, x=40, y=24){
      pieceCounter += 1;
      const circle = document.createElement('div');
      circle.className = 'piece circle-piece';
      circle.dataset.kind = 'circle';
      circle.dataset.id = pieceCounter;
      circle.dataset.n = n;
      circle.dataset.d = d;
      circle.dataset.filled = n;
      circle.style.left = x + 'px';
      circle.style.top = y + 'px';

      const label = document.createElement('div');
      label.className = 'piece-label';
      circle.appendChild(label);

      renderCircle(circle);
      attachPieceEvents(circle);
      board.appendChild(circle);
      selectPiece(circle);
      updateStatus(`Se agregó el círculo ${formatFraction(n,d)} al tablero.`);
    }

    function updateStatus(msg){
      statusText.textContent = msg;
    }

    function selectPiece(piece){
      if(selectedPiece) selectedPiece.classList.remove('selected');
      selectedPiece = piece;
      if(selectedPiece){
        selectedPiece.classList.add('selected');
        updateStatus(`Seleccionada la pieza ${formatFraction(+piece.dataset.n, +piece.dataset.d)}.`);
      }
    }


    function getConnectedRodGroup(seed){
      const rods = Array.from(board.querySelectorAll('.piece[data-kind="rod"]'));
      const d = Number(seed.dataset.d);
      const group = [seed];
      const seen = new Set([seed]);
      let changed = true;

      while(changed){
        changed = false;
        for(const rod of rods){
          if(seen.has(rod)) continue;
          if(Number(rod.dataset.d) !== d) continue;

          const ry = parseFloat(rod.style.top);
          const touchesGroup = group.some(g => {
            const gy = parseFloat(g.style.top);
            if(Math.abs(ry - gy) > 10) return false;
            const gl = parseFloat(g.style.left);
            const gr = gl + g.offsetWidth;
            const rl = parseFloat(rod.style.left);
            const rr = rl + rod.offsetWidth;
            return Math.abs(gr - rl) <= 2 || Math.abs(rr - gl) <= 2 || (rl >= gl && rl <= gr) || (gl >= rl && gl <= rr);
          });

          if(touchesGroup){
            group.push(rod);
            seen.add(rod);
            changed = true;
          }
        }
      }

      return group.sort((a,b)=> parseFloat(a.style.left) - parseFloat(b.style.left));
    }

    function clampGroupPosition(group, dx, dy){
      let minLeft = Infinity, minTop = Infinity, maxRight = -Infinity, maxBottom = -Infinity;
      group.forEach(piece => {
        const left = parseFloat(piece.style.left);
        const top = parseFloat(piece.style.top);
        minLeft = Math.min(minLeft, left);
        minTop = Math.min(minTop, top);
        maxRight = Math.max(maxRight, left + piece.offsetWidth);
        maxBottom = Math.max(maxBottom, top + piece.offsetHeight);
      });

      if(minLeft + dx < 0) dx = -minLeft;
      if(minTop + dy < 0) dy = -minTop;
      if(maxRight + dx > board.clientWidth) dx = board.clientWidth - maxRight;
      if(maxBottom + dy > board.clientHeight) dy = board.clientHeight - maxBottom;

      return {dx, dy};
    }

    function attachPieceEvents(piece){
      piece.addEventListener('pointerdown', startDrag);
      piece.addEventListener('click', (e)=>{
        e.stopPropagation();
        selectPiece(piece);
      });
      piece.addEventListener('dblclick', ()=>{
        const wasRod = piece.dataset.kind === 'rod';
        piece.remove();
        if(selectedPiece === piece) selectedPiece = null;
        if(wasRod) updateRodGroupLabels();
        updateStatus('Pieza eliminada.');
      });
    }

    function clampPosition(piece, x, y){
      x = Math.max(0, Math.min(board.clientWidth - piece.offsetWidth, x));
      y = Math.max(0, Math.min(board.clientHeight - piece.offsetHeight, y));
      return { x, y };
    }

    function startDrag(e){
      e.preventDefault();
      const piece = e.currentTarget;
      selectPiece(piece);

      const boardRect = board.getBoundingClientRect();
      const startPointerX = e.clientX - boardRect.left;
      const startPointerY = e.clientY - boardRect.top;

      let dragGroup = [piece];
      let initialPositions = [];

      if(piece.dataset.kind === 'rod'){
        dragGroup = getConnectedRodGroup(piece);
      }

      initialPositions = dragGroup.map(p => ({
        piece: p,
        left: parseFloat(p.style.left),
        top: parseFloat(p.style.top)
      }));

      function move(ev){
        const currentX = ev.clientX - boardRect.left;
        const currentY = ev.clientY - boardRect.top;
        let dx = currentX - startPointerX;
        let dy = currentY - startPointerY;

        const clamped = clampGroupPosition(dragGroup, dx, dy);
        dx = clamped.dx;
        dy = clamped.dy;

        initialPositions.forEach(item => {
          item.piece.style.left = (item.left + dx) + 'px';
          item.piece.style.top = (item.top + dy) + 'px';
        });
        if(piece.dataset.kind === 'rod'){
          updateRodGroupLabels();
        }
      }

      function up(){
        window.removeEventListener('pointermove', move);
        window.removeEventListener('pointerup', up);
        if(piece.dataset.kind === 'rod') {
          dragGroup.forEach(r => snapRodIfClose(r));
          updateRodGroupLabels();
        } else if(piece.dataset.kind === 'circle') {
          mergeCircleIfClose(piece);
        }
      }

      window.addEventListener('pointermove', move);
      window.addEventListener('pointerup', up);
    }


    function getRectData(piece){
      const left = parseFloat(piece.style.left);
      const top = parseFloat(piece.style.top);
      return {
        left, top,
        right:left + piece.offsetWidth,
        bottom:top + piece.offsetHeight,
        width:piece.offsetWidth,
        height:piece.offsetHeight
      };
    }

    function snapRodIfClose(activeRod){
      const active = getRectData(activeRod);
      const rods = Array.from(board.querySelectorAll('.piece[data-kind="rod"]')).filter(r => r !== activeRod);
      let best = null;

      function consider(candidate){
        if(!candidate || candidate.gap > SNAP_DISTANCE) return;
        if(!best || candidate.gap < best.gap) best = candidate;
      }

      rods.forEach(r => {
        const other = getRectData(r);

        if(Math.abs(other.top - active.top) <= SNAP_DISTANCE){
          consider({ gap: Math.abs(other.right - active.left), x: other.right, y: other.top });
          consider({ gap: Math.abs(other.left - active.right), x: other.left - active.width, y: other.top });
        }

        if(Math.abs(other.left - active.left) <= SNAP_DISTANCE){
          consider({ gap: Math.abs(other.bottom - active.top), x: other.left, y: other.bottom });
          consider({ gap: Math.abs(other.top - active.bottom), x: other.left, y: other.top - active.height });
        }

        if(Math.abs(other.right - active.right) <= SNAP_DISTANCE){
          consider({ gap: Math.abs(other.bottom - active.top), x: other.right - active.width, y: other.bottom });
          consider({ gap: Math.abs(other.top - active.bottom), x: other.right - active.width, y: other.top - active.height });
        }
      });

      const nearestRow = Math.round(active.top / 56) * 56;
      consider({ gap: Math.abs(nearestRow - active.top), x: active.left, y: nearestRow });
      consider({ gap: Math.abs(active.left - 24), x: 24, y: active.top });

      if(best){
        const pos = clampPosition(activeRod, best.x, best.y);
        activeRod.style.left = pos.x + 'px';
        activeRod.style.top = pos.y + 'px';
      }
    }


    function mergeCircleIfClose(activeCircle){
      const active = getRectData(activeCircle);
      const circles = Array.from(board.querySelectorAll('.piece[data-kind="circle"]')).filter(c => c !== activeCircle);
      let target = null;
      let bestGap = Infinity;

      circles.forEach(c => {
        if(c.dataset.d !== activeCircle.dataset.d) return;
        const other = getRectData(c);
        const cx1 = active.left + active.width / 2;
        const cy1 = active.top + active.height / 2;
        const cx2 = other.left + other.width / 2;
        const cy2 = other.top + other.height / 2;
        const dist = Math.hypot(cx1 - cx2, cy1 - cy2);
        if(dist <= 36 && dist < bestGap){
          bestGap = dist;
          target = c;
        }
      });

      if(!target) return;

      const d = Number(target.dataset.d);
      const filledTarget = Number(target.dataset.filled || 1);
      const filledActive = Number(activeCircle.dataset.filled || 1);
      const newFilled = Math.min(d, filledTarget + filledActive);

      target.dataset.filled = String(newFilled);
      renderCircle(target);

      if(selectedPiece === activeCircle){
        selectedPiece = target;
        target.classList.add('selected');
      }
      activeCircle.remove();
      updateStatus(`El círculo se completó a ${newFilled}/${d}.`);
    }

    function clearBoard(){
      Array.from(board.querySelectorAll('.piece, .group-label')).forEach(p => p.remove());
      selectedPiece = null;
      updateStatus('Tablero limpio.');
    }

    function setMode(mode){
      currentMode = mode;
      const showRods = mode === 'rods';
      rodPanel.classList.toggle('hidden', !showRods);
      circlePanel.classList.toggle('hidden', showRods);
      showRodsBtn.classList.toggle('active', showRods);
      showCirclesBtn.classList.toggle('active', !showRods);
      updateStatus(showRods ? 'Modo regletas activo.' : 'Modo círculos activo.');
    }

    document.getElementById('clearBoard').addEventListener('click', clearBoard);
    showRodsBtn.addEventListener('click', ()=> setMode('rods'));
    showCirclesBtn.addEventListener('click', ()=> setMode('circles'));

    toggleLabels.addEventListener('change', ()=>{
      board.querySelectorAll('.piece[data-kind="circle"] .piece-label').forEach(el => {
        el.style.display = toggleLabels.checked ? 'flex' : 'none';
      });
      updateRodGroupLabels();
    });

    maxDenSelect.addEventListener('change', ()=>{
      const maxDen = Number(maxDenSelect.value);
      buildRodLibrary(maxDen);
      buildCircleLibrary(maxDen);
    });

    board.addEventListener('click', ()=>{
      if(selectedPiece) selectedPiece.classList.remove('selected');
      selectedPiece = null;
      updateStatus('Sin selección.');
    });

    window.addEventListener('keydown', (e)=>{
      if((e.key === 'Delete' || e.key === 'Backspace') && selectedPiece){
        const wasRod = selectedPiece.dataset.kind === 'rod';
        selectedPiece.remove();
        selectedPiece = null;
        if(wasRod) updateRodGroupLabels();
        updateStatus('Pieza eliminada.');
      }
    });

    copyright.textContent = `© ${new Date().getFullYear()} Aneudy Minier | Simulador de Regletas de Fracciones`;

    const maxDen = Number(maxDenSelect.value);
    buildRodLibrary(maxDen);
    buildCircleLibrary(maxDen);
    setMode('rods');
  </script>
</body>
</html>
